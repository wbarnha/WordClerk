<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>3e0d3ccf-cbc6-4a3c-a29a-75d96be5bf89</Id>
  <!-- This value is a LOCAL/DEV DEFAULT ONLY, never what actually ships in a real release. CI's
       publish job (.github/workflows/ci.yml, triggered by a published GitHub Release) overwrites
       this at build time to "<release-tag-without-v>.0" via webpack.config.js's
       OPENCLERK_MANIFEST_VERSION substitution, e.g. tag v1.2.3 becomes packaged
       <Version>1.2.3.0</Version>. That step hard-fails the release if the tag's major version is
       below 1, since the Office manifest validator rejects any <Version> below 1.0, so this
       coupling only takes effect once the project's own tags reach v1.0.0+ (currently v0.3.0; see
       SUBMISSION.md § 1). Until then, every release build fails at "Derive manifest version from
       release tag" by design, rather than silently shipping a Version out of sync with the tag. -->
  <Version>1.0.0.0</Version>
  <!-- ProviderName MUST match the Publisher display name on the Partner Center account that submits
       this add-in, or AppSource validation rejects the submission. Update if the submitting account
       uses a different legal/display name. -->
  <ProviderName>William Barnhart</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="OpenClerk"/>
  <Description DefaultValue="Hyperlink, Bluebook-check, and verify legal case-law citations in Word. Flags likely-fabricated citations and embeds cited opinion text. Optional lookups use CourtListener or your firm's Westlaw, LexisNexis, or Bloomberg Law credentials."/>
  <IconUrl DefaultValue="https://localhost:3000/assets/logo-filled-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/logo-filled-64.png"/>
  <SupportUrl DefaultValue="https://github.com/OpenClerkProject/openclerk-word/issues"/>
  <!-- www.courtlistener.com is the only external service OpenClerk calls out of the box (free case-law
       lookup, see src/taskpane/providers/courtListenerProvider.ts). LexisNexis/Westlaw/Bloomberg Law
       lookups are opt-in and use a tenant-specific API base URL the user supplies at runtime (see
       README.md "Plugin architecture" and "Security & IT review" sections); add your firm's specific
       API domain here if your security policy requires every contacted domain to be allow-listed. -->
  <AppDomains>
    <AppDomain>https://www.courtlistener.com</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Document"/>
  </Hosts>
  <!-- WordApi 1.4 is the true floor for this add-in: the Embed Cited Text feature uses the comments
       API (Range.insertComment / Body.getComments), added in WordApi 1.4. Every other API used
       (search, insertHtml/insertText/insertOoxml, Range.hyperlinks) sits at or below 1.4; nothing
       needs 1.5+. Requiring 1.4 keeps perpetual/volume-licensed Word (2019/2021/LTSC) supported
       alongside Microsoft 365 and Word on the web, the broad cross-platform reach the code already
       targets (see the getComments-over-document.comments note in word.ts). AddInCommands is
       intentionally NOT required here: gating on it would stop the add-in loading on hosts that
       support task panes but not ribbon commands, and the commands degrade gracefully on their own. -->
  <Requirements>
    <Sets DefaultMinVersion="1.4">
      <Set Name="WordApi" MinVersion="1.4"/>
    </Sets>
  </Requirements>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://localhost:3000/assets/logo-filled-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://localhost:3000/assets/logo-filled-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://localhost:3000/assets/logo-filled-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://github.com/OpenClerkProject/openclerk-word#readme"/>
        <bt:Url id="Commands.Url" DefaultValue="https://localhost:3000/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://localhost:3000/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="OpenClerk is ready"/>
        <bt:String id="CommandsGroup.Label" DefaultValue="OpenClerk"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="Show Task Pane"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="OpenClerk loaded successfully. On the Home tab, click 'Show Task Pane' to hyperlink, check, and verify legal citations."/>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the OpenClerk task pane to hyperlink, Bluebook-check, and verify legal citations"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>