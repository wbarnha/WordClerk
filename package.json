{
  "name": "office-addin-taskpane",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenClerkProject/openclerk-word.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "word",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "webpack --mode production && node scripts/build-docs.js",
    "build:dev": "webpack --mode development",
    "build:docs": "node scripts/build-docs.js",
    "dev-server": "webpack serve --mode development",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "prettier": "office-addin-lint prettier",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "recover:start": "office-addin-dev-settings clear manifest.xml && office-addin-debugging stop manifest.xml && office-addin-debugging start manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "package": "npm run build --if-present && node scripts/package-release.js",
    "package:offline": "node scripts/package-release-offline.js",
    "install:addin": "node scripts/install-openclerk.js",
    "install:addin:dry-run": "node scripts/install-openclerk.js --dry-run",
    "watch": "webpack --mode development --watch",
    "convert-logos": "node scripts/convert-logos.js",
    "bluebook:update-data": "node scripts/generate-bluebook-data.js",
    "test": "jest",
    "test:live": "jest tests/courtListener.live.test.ts"
  },
  "dependencies": {
    "@types/jszip": "^3.4.0",
    "core-js": "^3.36.0",
    "jszip": "^3.10.1",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-typescript": "^7.23.3",
    "@types/jest": "^29.0.0",
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "archiver": "^5.3.1",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "eslint-plugin-office-addins": "^4.0.3",
    "file-loader": "^6.2.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.0.0",
    "marked": "^18.0.5",
    "office-addin-cli": "^2.0.6",
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-certs": "^2.0.6",
    "office-addin-lint": "^3.0.6",
    "office-addin-manifest": "^2.1.2",
    "office-addin-prettier-config": "^2.0.1",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "sharp": "^0.32.0",
    "source-map-loader": "^5.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.2",
    "webpack": "^5.105.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "5.2.6"
  },
  "_overridesRationale": "Forces patched versions of two transitively-vulnerable devDependencies (GHSA-w5hq-g745-h8pq via uuid, GHSA-5c6j-r48x-rmvq/GHSA-qj8w-gfj5-8c6v via serialize-javascript) without waiting on upstream packages to bump their own dependency ranges. See README.md > Dependency security fixes for the full explanation of every advisory addressed on this branch.",
  "overrides": {
    "uuid": "^14.0.1",
    "serialize-javascript": "^7.0.7"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 versions",
    "ie 11"
  ]
}
